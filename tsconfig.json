{
  "compilerOptions": {
    "outDir": "./dist/",
    "rootDir": "./src/",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "target": "ES2022",
    "moduleResolution": "bundler",
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  },
  "files": [
    "./src/Plugin.ts"
  ]
}
